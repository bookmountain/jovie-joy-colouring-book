# Copy this file to one of:
#   apps/api/.env.local   → loaded when running `dotnet run` locally (takes precedence)
#   apps/api/.env         → loaded in production (inside Docker)
#
# Both files are gitignored. The docker-compose files read the POSTGRES_* vars
# below via variable interpolation, so keep them consistent with ConnectionStrings__Default.

ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://0.0.0.0:8080

# --- database ---
POSTGRES_USER=jovie
POSTGRES_PASSWORD=change_me
POSTGRES_DB=jovie_joy
# Optional overrides for docker-compose.prod.yml. Production defaults to
# shared-postgres:5432 when these are omitted.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
ConnectionStrings__Default=Host=localhost;Port=5432;Database=jovie_joy;Username=jovie;Password=change_me

# --- JWT ---
# openssl rand -base64 48
Jwt__Secret=change_me_at_least_32_bytes_of_random
Jwt__Issuer=jovie-joy-api
Jwt__Audience=jovie-joy-web
Jwt__ExpiryMinutes=60

# --- Google OAuth ---
Google__ClientId=your-client-id.apps.googleusercontent.com
Google__ClientSecret=your-client-secret
Google__RedirectUri=http://localhost:8080/auth/google/callback

# --- Frontend URL (CORS + post-auth redirect) ---
WebAppUrl=http://localhost:3000

# --- Stripe ---
Stripe__SecretKey=sk_test_REPLACE_ME
Stripe__WebhookSecret=whsec_REPLACE_ME
Stripe__SuccessUrl=http://localhost:3000/checkout/success?session_id={CHECKOUT_SESSION_ID}
Stripe__CancelUrl=http://localhost:3000/checkout

# --- Admin seed (used only on first startup) ---
Admin__Email=admin@joviejoy.com
Admin__Password=change_me
