# --- runtime ---
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://0.0.0.0:8080

# --- database ---
# Local dev (docker-compose.yml) runs Postgres on host port 5433
ConnectionStrings__Default=Host=localhost;Port=5433;Database=jovie_joy;Username=jovie;Password=jovie_dev

# --- JWT ---
# Generate a real secret: openssl rand -base64 48
Jwt__Secret=dev-secret-change-me-dev-secret-change-me-dev-secret
Jwt__Issuer=jovie-joy-api
Jwt__Audience=jovie-joy-web
Jwt__ExpiryMinutes=60

# --- Google OAuth ---
# Google Cloud Console -> APIs & Services -> Credentials -> OAuth client ID (Web)
Google__ClientId=your-client-id.apps.googleusercontent.com
Google__ClientSecret=your-client-secret
Google__RedirectUri=http://localhost:5080/auth/google/callback

# --- Frontend URL (for CORS + post-auth redirect) ---
WebAppUrl=http://localhost:3000

# --- Stripe ---
Stripe__SecretKey=sk_test_REPLACE_ME
Stripe__WebhookSecret=whsec_REPLACE_ME
Stripe__SuccessUrl=http://localhost:3000/checkout/success?session_id={CHECKOUT_SESSION_ID}
Stripe__CancelUrl=http://localhost:3000/checkout
